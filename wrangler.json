{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "portal-doaction",
  "main": "./workers/app.ts",
  "compatibility_date": "2025-10-08",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "observability": {
    "enabled": true
  },
  "routes": [
    {
      "pattern": "portal.doaction.co.th",
      "zone_name": "doaction.co.th",
      "custom_domain": true
    }
  ],
  "upload_source_maps": true,
  "vars": {
    "VALUE_FROM_CLOUDFLARE": "Hello from Cloudflare",
    "APP_URL": "https://portal.doaction.co.th",
    "SESSION_SECRET": "y8N4vQ2mK7pLx3Rz9tW6cJ1hF5uD0sBa"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "portal",
      "database_id": "b9e1971c-8c20-42ad-a0e6-5c28b38994a7",
      "remote": true
    }
  ],
  "kv_namespaces": [
    {
      "binding": "SESSIONPORTAL",
      "id": "5223ac89a8474cd4b972b490f357bdd5",
      "remote": true
    }
  ],
  "r2_buckets": [
    {
      "binding": "ATTACHMENTS",
      "bucket_name": "portal",
      "remote": true
    }
  ],
  "send_email": [
    {
      "name": "SEND_EMAIL",
      "remote": true
    }
  ],
}